<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
  <div>
    <h2 class="mb-1">Farmer Dashboard</h2>
    <p class="text-muted mb-0">Track earnings, review incoming orders, and update fulfilment status.</p>
  </div>
  <a href="/product" class="btn btn-outline-secondary">Manage Products</a>
</div>

<% if (message) { %>
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <%= message %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>
<% if (error) { %>
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<div class="row g-4 mb-5">
  <div class="col-md-6 col-xl-3">
    <div class="card glass-card border-0 shadow-sm">
      <div class="card-body">
        <div class="text-muted small">Products Listed</div>
        <div class="display-6 fw-bold"><%= summary.total_products %></div>
      </div>
    </div>
  </div>
  <div class="col-md-6 col-xl-3">
    <div class="card glass-card border-0 shadow-sm">
      <div class="card-body">
        <div class="text-muted small">Incoming Orders</div>
        <div class="display-6 fw-bold"><%= summary.total_orders %></div>
      </div>
    </div>
  </div>
  <div class="col-md-6 col-xl-3">
    <div class="card glass-card border-0 shadow-sm">
      <div class="card-body">
        <div class="text-muted small">Delivered Revenue</div>
        <div class="display-6 fw-bold">Rs. <%= summary.delivered_revenue.toFixed(2) %></div>
      </div>
    </div>
  </div>
  <div class="col-md-6 col-xl-3">
    <div class="card glass-card border-0 shadow-sm">
      <div class="card-body">
        <div class="text-muted small">Open Order Value</div>
        <div class="display-6 fw-bold">Rs. <%= summary.open_order_value.toFixed(2) %></div>
      </div>
    </div>
  </div>
</div>

<div class="row g-4 mb-5">
  <div class="col-md-6">
    <div class="card glass-card border-0 shadow-sm">
      <div class="card-body">
        <div class="text-muted small">Total Quantity Sold</div>
        <div class="display-6 fw-bold"><%= summary.total_quantity_sold.toFixed(2) %> kg</div>
      </div>
    </div>
  </div>
</div>

<h3 class="mb-3">Incoming Customer Orders</h3>
<div class="glass-container p-0 overflow-hidden">
  <table class="table table-hover align-middle mb-0">
    <thead class="table-dark">
      <tr>
        <th class="ps-4">Order</th>
        <th>Product</th>
        <th>Customer</th>
        <th>Payment</th>
        <th>Delivery Address</th>
        <th>Status</th>
        <th>Refund</th>
        <th class="pe-4">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (orders.length === 0) { %>
        <tr><td colspan="8" class="text-center py-4 text-muted">No incoming orders yet.</td></tr>
      <% } %>
      <% orders.forEach(o => { %>
        <tr>
          <td class="ps-4">
            <strong>#<%= o.order_id %></strong>
            <div class="small text-muted"><%= new Date(o.order_date).toLocaleString() %></div>
          </td>
          <td>
            <strong><%= o.product_name %></strong>
            <div class="small text-muted"><%= o.quantity %> kg</div>
            <div class="small text-success">Rs. <%= (o.quantity * o.price).toFixed(2) %></div>
          </td>
          <td>
            <strong><%= o.customer_name %></strong>
            <div class="small text-muted"><%= o.customer_phone || 'No phone' %></div>
            <div class="small text-muted"><%= o.customer_email || 'No email' %></div>
          </td>
          <td><%= o.payment_mode %></td>
          <td><%= o.delivery_address || 'N/A' %></td>
          <td>
            <span class="badge <%= o.order_status === 'Delivered' ? 'bg-success' : o.order_status === 'Shipped' ? 'bg-primary' : o.order_status === 'Packed' ? 'bg-info text-dark' : o.order_status === 'Cancelled' ? 'bg-danger' : 'bg-warning text-dark' %> rounded-pill">
              <%= o.order_status %>
            </span>
          </td>
          <td>
            <% if (o.order_status === 'Cancelled') { %>
              <div class="small text-success"><%= Number(o.refund_percent || 0) %>%</div>
              <div class="small text-muted">Rs. <%= Number(o.refund_amount || 0).toFixed(2) %></div>
            <% } else { %>
              <span class="small text-muted">-</span>
            <% } %>
          </td>
          <td class="pe-4">
            <% if (o.order_status === 'Cancelled') { %>
              <span class="small text-muted">Cancelled by customer</span>
            <% } else { %>
              <form action="/farmer/order/<%= o.order_id %>/status" method="POST" class="d-flex flex-wrap gap-2">
                <button type="submit" name="status" value="Packed" class="btn btn-outline-info btn-sm">Packed</button>
                <button type="submit" name="status" value="Shipped" class="btn btn-outline-primary btn-sm">Shipped</button>
                <button type="submit" name="status" value="Delivered" class="btn btn-outline-success btn-sm">Delivered</button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
