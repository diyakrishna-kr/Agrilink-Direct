<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
  <div>
    <h2 class="mb-1">Manage My Products</h2>
    <p class="text-muted mb-0">Add products, adjust stock, and manage manual discounts from here.</p>
  </div>
  <a href="/farmer/dashboard" class="btn btn-outline-secondary">View Farmer Dashboard</a>
</div>

<% if (message) { %>
  <div class="alert alert-success"><%= message %></div>
<% } %>
<% if (error) { %>
  <div class="alert alert-danger"><%= error %></div>
<% } %>

<div class="card bg-light p-4 mb-5 border-0 shadow-sm">
    <h4 class="mb-3">Add New Product</h4>
    <form method="post" action="/product" enctype="multipart/form-data" class="row g-3">
        <div class="col-md-3">
            <label class="form-label">Product Name</label>
            <input name="product_name" class="form-control" placeholder="e.g. Tomatoes" required>
        </div>
        <div class="col-md-2">
            <label class="form-label">Category</label>
            <select name="category" class="form-select" required>
                <option value="Vegetable">Vegetable</option>
                <option value="Fruit">Fruit</option>
                <option value="Grain">Grain</option>
                <option value="Spice">Spice</option>
                <option value="Dairy">Dairy</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Price / Kg (Rs.)</label>
            <input name="price_per_kg" type="number" step="0.01" class="form-control" placeholder="0.00" required>
        </div>
        <div class="col-md-2">
            <label class="form-label">Stock (Kg)</label>
            <input name="available_quantity" type="number" step="0.01" class="form-control" placeholder="Qty" required>
        </div>
        <div class="col-md-3">
            <label class="form-label">Expiry Date</label>
            <input type="date" name="expiry_date" class="form-control" required>
        </div>
        <div class="col-md-3">
            <label class="form-label">Manual Discount %</label>
            <input name="manual_discount_percent" type="number" min="0" max="80" step="1" class="form-control" value="0">
        </div>
        <div class="col-md-4">
            <label class="form-label">Product Image</label>
            <input type="file" name="image" class="form-control" accept="image/*" required>
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button class="btn btn-success w-100">List Product</button>
        </div>
    </form>
</div>

<h4>My Listed Products</h4>
<table class="table table-hover align-middle">
  <thead class="table-dark">
      <tr>
          <th>Image</th>
          <th>Name</th>
          <th>Category</th>
          <th>Price/kg</th>
          <th>Expiry</th>
          <th>Discount</th>
          <th>Available Stock</th>
          <th>Actions</th>
      </tr>
  </thead>
  <tbody>
    <% if (products.length === 0) { %>
        <tr><td colspan="8" class="text-center">You haven't listed any products yet.</td></tr>
    <% } %>
    <% products.forEach(p => { %>
      <tr>
        <td>
            <% if (p.image_url) { %>
                <img src="<%= p.image_url.startsWith('http') ? p.image_url : '/uploads/' + p.image_url %>" class="product-img shadow-sm">
            <% } else { %>
                <span class="text-muted">N/A</span>
            <% } %>
        </td>
        <td><strong><%= p.product_name %></strong></td>
        <td><span class="badge bg-secondary"><%= p.category %></span></td>
        <td>
          <% if (p.discount_percent > 0) { %>
            <div class="text-decoration-line-through text-muted small">Rs. <%= p.original_price_per_kg.toFixed(2) %></div>
            <div class="fw-bold text-success">Rs. <%= p.discounted_price_per_kg.toFixed(2) %></div>
          <% } else { %>
            Rs. <%= p.original_price_per_kg.toFixed(2) %>
          <% } %>
        </td>
        <td>
          <%= p.expiry_display %>
          <% if (p.is_expired) { %>
            <div><span class="badge bg-danger">Expired</span></div>
          <% } else if (p.is_near_expiry) { %>
            <div><span class="badge bg-warning text-dark">Near expiry</span></div>
          <% } %>
        </td>
        <td>
          <div>Manual: <%= p.manual_discount_percent %>%</div>
          <% if (p.near_expiry_discount_percent > 0) { %>
            <div class="small text-warning">Near expiry: <%= p.near_expiry_discount_percent %>%</div>
          <% } %>
          <div class="small text-success">Applied: <%= p.discount_percent %>%</div>
        </td>
        <td><%= p.available_quantity %> kg</td>
        <td>
          <div class="d-flex flex-column gap-2">
            <a href="/product/<%= p.product_id %>/edit" class="btn btn-outline-primary btn-sm">Edit</a>
            <form action="/product/<%= p.product_id %>/delete" method="POST">
              <button type="submit" class="btn btn-outline-danger btn-sm w-100">Delete</button>
            </form>
          </div>
        </td>
      </tr>
    <% }); %>
  </tbody>
</table>
