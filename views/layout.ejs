<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Agrilink Direct</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/styles.css" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body>
  <div class="container mt-3 mb-4 glass-container app-shell">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-3 topbar">
      <div class="d-flex align-items-center flex-wrap gap-3">
        <a href="/" class="brand-logo-link">
          <img src="/images/agrilink-direct-logo.jpeg" alt="Agrilink Direct" class="brand-logo">
        </a>
        <nav class="nav nav-pills header-nav">
          <a class="nav-link <%= currentPath === '/' ? 'active' : '' %>" href="/">Home</a>
          <a class="nav-link <%= currentPath === '/farmer' ? 'active' : '' %>" href="/farmer">Farmers Directory</a>
          <a class="nav-link <%= currentPath === '/customer' ? 'active' : '' %>" href="/customer">Customers Directory</a>
        </nav>
      </div>
      <div class="user-actions">
        <% if (user) { %>
          <span class="me-3">Welcome, <strong>
              <%= user.name %>
            </strong> (<%= userType %>)</span>
          <a href="/logout" class="btn btn-sm btn-outline-danger">Logout</a>
        <% } else { %>
          <a href="/login" class="btn btn-sm btn-outline-primary">Login</a>
          <a href="/register" class="btn btn-sm btn-primary">Register</a>
        <% } %>
      </div>
    </div>

    <nav class="nav nav-pills mb-3 main-nav">
      <% if (userType==='farmer' ) { %>
        <a class="nav-link <%= currentPath === '/farmer/dashboard' ? 'active' : '' %>" href="/farmer/dashboard">Farmer Dashboard</a>
        <a class="nav-link <%= currentPath === '/product' || currentPath.startsWith('/product/') ? 'active' : '' %>" href="/product">Manage Products</a>
        <% } %>
          <% if (userType==='admin' ) { %>
            <a class="nav-link <%= currentPath === '/admin' ? 'active' : '' %>" href="/admin">Admin Dashboard</a>
            <% } %>
          <% if (userType==='customer' ) { %>
            <a class="nav-link <%= currentPath === '/order' || currentPath === '/checkout' ? 'active' : '' %>" href="/order">My Orders / Bag (<%= cartCount %>)</a>
            <% } %>
    </nav>

    <div class="card p-3 p-lg-4 shadow-sm content-panel">
      <%- body %>
    </div>
  </div>
</body>

</html>
