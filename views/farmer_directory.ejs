<h2 class="mb-4">Farmers Directory</h2>

<div class="row row-cols-1 row-cols-md-2 g-4">
  <% farmers.forEach(f => { %>
    <div class="col">
      <div class="card h-100 shadow-sm glass-card border-0">
        <div class="card-body">
          <h5 class="card-title fw-bold"><%= f.name %></h5>
          <p class="card-text mb-1"><strong>Location:</strong> <%= f.location %></p>
          <p class="card-text"><strong>Contact:</strong> <%= f.phone %></p>
        </div>
      </div>
    </div>
  <% }) %>
</div>
