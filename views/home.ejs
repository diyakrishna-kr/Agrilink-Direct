<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2 page-toolbar">
    <h2 class="mb-0">Available Products</h2>
    <form class="d-flex flex-wrap w-50 min-search home-search" method="GET" action="/">
        <input class="form-control me-2 rounded-pill px-4" type="search" name="q" placeholder="Search products, categories, or farmers..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
        <input type="hidden" name="category" value="<%= typeof selectedCategory !== 'undefined' ? selectedCategory : '' %>">
        <input type="hidden" name="group" value="<%= typeof selectedGroup !== 'undefined' ? selectedGroup : '' %>">
        <button class="btn btn-outline-success rounded-pill px-4 fw-bold" type="submit">Search</button>
        <% if (typeof searchQuery !== 'undefined' && searchQuery !== '') { %>
            <a href="/<%= (() => { const params = []; if (typeof selectedCategory !== 'undefined' && selectedCategory) params.push('category=' + encodeURIComponent(selectedCategory)); if (typeof selectedGroup !== 'undefined' && selectedGroup) params.push('group=' + encodeURIComponent(selectedGroup)); return params.length ? '?' + params.join('&') : ''; })() %>" class="btn btn-outline-secondary rounded-pill ms-2">Clear</a>
        <% } %>
    </form>
</div>

<div class="d-flex flex-wrap gap-2 mb-3 home-filter-row">
  <a href="/" class="btn <%= !selectedCategory && !selectedGroup ? 'btn-success' : 'btn-outline-success' %>">All</a>
  <a href="/?category=Fruit" class="btn <%= selectedCategory === 'Fruit' ? 'btn-success' : 'btn-outline-success' %>">Fruits</a>
  <a href="/?category=Vegetable" class="btn <%= selectedCategory === 'Vegetable' ? 'btn-success' : 'btn-outline-success' %>">Vegetables</a>
  <a href="/?category=Dairy" class="btn <%= selectedCategory === 'Dairy' ? 'btn-success' : 'btn-outline-success' %>">Dairy</a>
  <a href="/?category=Spice" class="btn <%= selectedCategory === 'Spice' ? 'btn-success' : 'btn-outline-success' %>">Spices</a>
  <a href="/?group=cereals" class="btn <%= selectedGroup === 'cereals' ? 'btn-success' : 'btn-outline-success' %>">Cereals</a>
  <a href="/?group=pulses" class="btn <%= selectedGroup === 'pulses' ? 'btn-success' : 'btn-outline-success' %>">Pulses</a>
</div>

<div class="row row-cols-1 row-cols-md-3 g-3 product-grid">
  <% if (products.length === 0) { %>
    <div class="col-12"><p class="text-muted">No products available at the moment.</p></div>
  <% } %>
  <% products.forEach(p => { %>
    <div class="col">
      <div class="card h-100 shadow-sm glass-card border-0">
        <% if (p.image_url) { %>
            <img src="<%= p.image_url.startsWith('http') ? p.image_url : '/uploads/' + p.image_url %>" class="card-img-top product-card-image" alt="<%= p.product_name %>">
        <% } else { %>
            <div class="card-img-top product-card-image bg-light d-flex align-items-center justify-content-center">
                <span class="text-muted">No Image</span>
            </div>
        <% } %>
        <div class="card-body d-flex flex-column product-card-body">
          <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
            <h5 class="card-title mb-0"><%= p.product_name %></h5>
            <% if (p.is_expired) { %>
              <span class="badge bg-danger">Expired</span>
            <% } else if (p.is_near_expiry) { %>
              <span class="badge bg-warning text-dark"><%= p.discount_percent %>% off</span>
            <% } %>
          </div>
          <h6 class="card-subtitle mb-2 text-muted"><%= p.category %> | By <%= p.farmer_name %></h6>
          <% const displayOriginalPrice = typeof p.original_price_per_kg !== 'undefined' ? Number(p.original_price_per_kg) : Number(p.price_per_kg || 0); %>
          <% const displayDiscountedPrice = typeof p.discounted_price_per_kg !== 'undefined' ? Number(p.discounted_price_per_kg) : displayOriginalPrice; %>
          <% if (p.discount_percent > 0) { %>
            <p class="card-text mb-1">
              <strong>Price:</strong>
              <span class="text-decoration-line-through text-muted me-2">Rs. <%= displayOriginalPrice.toFixed(2) %></span>
              <span class="text-success fw-bold">Rs. <%= displayDiscountedPrice.toFixed(2) %>/kg</span>
            </p>
          <% } else { %>
            <p class="card-text mb-1"><strong>Price:</strong> Rs. <%= displayDiscountedPrice.toFixed(2) %>/kg</p>
          <% } %>
          <% if (p.review_count > 0) { %>
            <p class="card-text mb-1">
              <strong>Rating:</strong> <span class="text-warning"><%= p.average_rating.toFixed(1) %> / 5</span>
              <small class="text-muted">(<%= p.review_count %> review<%= p.review_count === 1 ? '' : 's' %>)</small>
            </p>
          <% } else { %>
            <p class="card-text mb-1"><strong>Rating:</strong> <span class="text-muted">No reviews yet</span></p>
          <% } %>
          <p class="card-text mb-1"><strong>Stock:</strong> <%= p.available_quantity %> kg</p>
          <p class="card-text mb-3"><strong>Expiry:</strong> <%= p.expiry_display %></p>
          
          <% if (userType === 'customer') { %>
             <% if (p.is_expired) { %>
               <div class="alert alert-danger py-2 mb-0 small mt-auto">This product has expired and cannot be added to your bag.</div>
             <% } else { %>
               <form action="/cart/add" method="POST" class="d-flex flex-column gap-2 mt-auto">
                 <input type="hidden" name="product_id" value="<%= p.product_id %>">
                 <input type="hidden" name="redirect_to" value="/order">
                 <div class="input-group input-group-sm">
                   <span class="input-group-text">Qty (kg)</span>
                   <input name="quantity" type="number" step="0.01" min="0.01" max="<%= p.available_quantity %>" class="form-control" value="1.00" required>
                 </div>
                 <button type="submit" class="btn btn-primary w-100">Buy Now</button>
               </form>
             <% } %>
          <% } else if (userType === null) { %>
             <a href="/login" class="btn btn-outline-primary w-100 mt-auto">Login to Order</a>
          <% } %>
        </div>
      </div>
    </div>
  <% }) %>
</div>
