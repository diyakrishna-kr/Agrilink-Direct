<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
  <div>
    <h2 class="mb-1">Edit Product</h2>
    <p class="text-muted mb-0">Update stock, price, expiry date, and manual discount for this listing.</p>
  </div>
  <a href="/product" class="btn btn-outline-secondary">Back to Products</a>
</div>

<% if (message) { %>
  <div class="alert alert-success"><%= message %></div>
<% } %>
<% if (error) { %>
  <div class="alert alert-danger"><%= error %></div>
<% } %>

<div class="card bg-light p-4 border-0 shadow-sm">
  <form method="post" action="/product/<%= product.product_id %>/edit" enctype="multipart/form-data" class="row g-3">
      <div class="col-md-4">
          <label class="form-label">Product Name</label>
          <input name="product_name" class="form-control" value="<%= product.product_name %>" required>
      </div>
      <div class="col-md-2">
          <label class="form-label">Category</label>
          <select name="category" class="form-select" required>
              <% ['Vegetable', 'Fruit', 'Grain', 'Spice', 'Dairy'].forEach(category => { %>
                <option value="<%= category %>" <%= product.category === category ? 'selected' : '' %>><%= category %></option>
              <% }) %>
          </select>
      </div>
      <div class="col-md-2">
          <label class="form-label">Price / Kg (Rs.)</label>
          <input name="price_per_kg" type="number" step="0.01" class="form-control" value="<%= product.original_price_per_kg %>" required>
      </div>
      <div class="col-md-2">
          <label class="form-label">Stock (Kg)</label>
          <input name="available_quantity" type="number" step="0.01" class="form-control" value="<%= product.available_quantity %>" required>
      </div>
      <div class="col-md-2">
          <label class="form-label">Manual Discount %</label>
          <input name="manual_discount_percent" type="number" min="0" max="80" step="1" class="form-control" value="<%= product.manual_discount_percent %>" required>
      </div>
      <div class="col-md-4">
          <label class="form-label">Expiry Date</label>
          <input type="date" name="expiry_date" class="form-control" value="<%= product.expiry_input_value %>" required>
      </div>
      <div class="col-md-4">
          <label class="form-label">Replace Product Image</label>
          <input type="file" name="image" class="form-control" accept="image/*">
      </div>
      <div class="col-md-4">
          <label class="form-label">Current Discounted Price</label>
          <input class="form-control" value="Rs. <%= product.discounted_price_per_kg.toFixed(2) %>" disabled>
      </div>
      <div class="col-12 d-flex gap-2">
          <button class="btn btn-success">Save Changes</button>
          <a href="/product" class="btn btn-outline-secondary">Cancel</a>
      </div>
  </form>
</div>
